---
import { skills, skillCategories } from '../data/skills';

const grouped = skillCategories.map((cat) => ({
  category: cat,
  items: skills.filter((s) => s.category === cat),
}));
---

<div class="skills-box section" id="skill">
  <div class="main-content">
    <h2 class="section-title"><span>SKILL</span></h2>
    {grouped.map(({ category, items }) => (
      <div class="skill-group">
        <h3 class="category-label">{category}</h3>
        <ul class="skill-list">
          {items.map((s) => (
            <li class="skill-item">
              <figure class="skill-icon">
                <img src={s.img} alt={s.alt} loading="lazy" />
              </figure>
              <div class="skill-name">{s.name}</div>
              <div class="skill-tags">
                {s.tags.map((t) => <span class="tag">{t}</span>)}
              </div>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </div>
</div>

<style>
  .skill-group {
    margin-bottom: 56px;
  }

  .skill-group:last-child {
    margin-bottom: 0;
  }

  .category-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.15em;
    color: var(--color-text-muted);
    text-transform: uppercase;
    margin: 0 0 20px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--color-border-light);
  }

  .skill-list {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .skill-item {
    width: calc(25% - 9px);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .skill-icon {
    margin: 0 0 8px;
    width: 64px;
    height: 64px;
    position: relative;
    overflow: hidden;
  }

  .skill-icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    transition: transform 0.3s ease;
  }

  .skill-icon:hover img {
    transform: scale(1.1);
  }

  .skill-name {
    font-size: 14px;
    font-weight: 600;
    margin-bottom: 4px;
    line-height: 1.3;
  }

  .skill-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
  }

  .tag {
    font-size: 10px;
    font-weight: 500;
    padding: 2px 6px;
    background: var(--color-accent);
    color: white;
    letter-spacing: 0.02em;
  }

  @media (max-width: 900px) {
    .skill-item {
      width: calc(33.333% - 8px);
    }
  }

  @media (max-width: 600px) {
    .skill-item {
      width: calc(50% - 6px);
    }

    .skill-icon {
      width: 52px;
      height: 52px;
    }
  }
</style>
