---
import { hobbies } from '../data/hobby';
import { oshi } from '../data/oshi';
import { resolveOshi } from '../lib/og';

// url があり img が空の推しは、ビルド時に og:image を取得して img を補完する
const oshiItems = await resolveOshi(oshi);
// マーキー1周の秒数。カード数に比例させてスクロール速度を一定に（最低18秒）
const marqueeDuration = Math.max(oshiItems.length * 6, 18);
---

<div class="hobby-box section" id="hobby">
  <div class="main-content">
    <h1 class="section-title"><span>HOBBY</span></h1>

    <ul class="hobby-list">
      {hobbies.map((h) => (
        <li class="hobby-item">
          <span class="hobby-title">{h.title}</span>
          {h.description && <span class="hobby-desc">{h.description}</span>}
        </li>
      ))}
    </ul>

    <h2 class="subsection-title">推し</h2>
    <div class="oshi-marquee">
      <div class="oshi-track" style={`animation-duration: ${marqueeDuration}s`}>
        {[...oshiItems, ...oshiItems].map((o, i) => {
          const dup = i >= oshiItems.length; // 後半はシームレスループ用の複製
          const Tag = o.url ? 'a' : 'div';
          const props = {
            class: `oshi-card${dup ? ' is-dup' : ''}`,
            ...(o.url ? { href: o.url, target: '_blank', rel: 'noopener noreferrer' } : {}),
            ...(dup ? { 'aria-hidden': 'true', tabindex: -1 } : {}),
          };
          return (
            <Tag {...props}>
              <div class="oshi-img">
                {o.img ? (
                  <img src={o.img} alt={o.name} loading="lazy" />
                ) : (
                  <span class="oshi-img-placeholder"><i class="fa-solid fa-heart"></i></span>
                )}
              </div>
              <div class="oshi-body">
                {o.category && <span class="oshi-category">{o.category}</span>}
                <p class="oshi-name">{o.name}</p>
                {o.description && <p class="oshi-desc">{o.description}</p>}
              </div>
            </Tag>
          );
        })}
      </div>
    </div>
  </div>
</div>

<style>
  /* ===== 趣味（テキスト主体のコンパクトカード） ===== */
  .hobby-list {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .hobby-item {
    display: flex;
    align-items: baseline;
    gap: 10px;
    border: 1px solid var(--color-border-light);
    border-radius: 8px;
    padding: 8px 14px;
  }

  .hobby-title {
    font-size: 14px;
    font-weight: bold;
  }

  .hobby-desc {
    font-size: 12px;
    color: var(--color-text-muted);
  }

  /* ===== サブセクション見出し（推し） ===== */
  .subsection-title {
    font-size: 1.1em;
    font-weight: bold;
    letter-spacing: 0.08em;
    margin: 36px 0 16px;
    padding-left: 10px;
    border-left: 4px solid var(--color-accent);
    line-height: 1.3;
  }

  /* ===== 推し（小さめカードを連続オートスクロール＝マーキー） ===== */
  .oshi-marquee {
    overflow: hidden;
    /* ホバー時の浮き＆影がクリップされないための縦余白 */
    padding: 8px 0 22px;
    /* 左右端をふわっとフェード */
    -webkit-mask-image: linear-gradient(to right, transparent, #000 24px, #000 calc(100% - 24px), transparent);
    mask-image: linear-gradient(to right, transparent, #000 24px, #000 calc(100% - 24px), transparent);
  }

  .oshi-track {
    display: flex;
    width: max-content;
    /* animation-duration はインラインで指定（カード数比例） */
    animation: oshi-scroll 36s linear infinite;
  }

  /* ホバー中は停止（カードを読む/クリックしやすく） */
  .oshi-marquee:hover .oshi-track {
    animation-play-state: paused;
  }

  @keyframes oshi-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  .oshi-card {
    flex: 0 0 auto;
    width: 140px;
    margin-right: 14px;   /* gap 相当。カード側に持たせて -50% ループを正確にする */
    border: 1px solid var(--color-border-light);
    border-radius: 10px;
    overflow: hidden;
    background: #fff;
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }

  .oshi-card:hover {
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.1);
    transform: translateY(-2px);
  }

  .oshi-img {
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
  }

  .oshi-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* 画像未設定時のプレースホルダー（ハート） */
  .oshi-img-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f5f5f5;
    color: var(--color-border-light);
    font-size: 36px;
  }

  .oshi-body {
    padding: 10px 12px 12px;
  }

  .oshi-category {
    display: inline-block;
    font-size: 9px;
    font-weight: 500;
    letter-spacing: 0.05em;
    padding: 2px 5px;
    margin-bottom: 6px;
    background: var(--color-accent);
    color: #fff;
  }

  .oshi-name {
    font-size: 13px;
    font-weight: bold;
    margin: 0 0 4px;
  }

  .oshi-desc {
    font-size: 11px;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin: 0;
  }

  /* 動きを減らす設定: オートスクロールを止め、複製を隠して折り返し表示 */
  @media (prefers-reduced-motion: reduce) {
    .oshi-track {
      animation: none;
      flex-wrap: wrap;
      width: 100%;
      row-gap: 14px;
    }

    .oshi-card.is-dup {
      display: none;
    }

    .oshi-marquee {
      padding-bottom: 8px;
      -webkit-mask-image: none;
      mask-image: none;
    }
  }
</style>
