---
import { hobbies } from '../data/hobby';
import { oshi } from '../data/oshi';
---

<div class="hobby-box section" id="hobby">
  <div class="main-content">
    <h1 class="section-title"><span>HOBBY</span></h1>

    <ul class="hobby-list">
      {hobbies.map((h) => (
        <li class="hobby-item">
          <span class="hobby-title">{h.title}</span>
          {h.description && <span class="hobby-desc">{h.description}</span>}
        </li>
      ))}
    </ul>

    <h2 class="subsection-title">推し</h2>
    <div class="oshi-scroller">
      {oshi.map((o) => {
        const Tag = o.url ? 'a' : 'div';
        const linkProps = o.url
          ? { href: o.url, target: '_blank', rel: 'noopener noreferrer' }
          : {};
        return (
          <Tag class="oshi-card" {...linkProps}>
            <div class="oshi-img">
              {o.img ? (
                <img src={o.img} alt={o.name} loading="lazy" />
              ) : (
                <span class="oshi-img-placeholder"><i class="fa-solid fa-heart"></i></span>
              )}
            </div>
            <div class="oshi-body">
              {o.category && <span class="oshi-category">{o.category}</span>}
              <p class="oshi-name">{o.name}</p>
              {o.description && <p class="oshi-desc">{o.description}</p>}
            </div>
          </Tag>
        );
      })}
    </div>
  </div>
</div>

<style>
  /* ===== 趣味（テキスト主体のコンパクトカード） ===== */
  .hobby-list {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .hobby-item {
    display: flex;
    align-items: baseline;
    gap: 10px;
    border: 1px solid var(--color-border-light);
    border-radius: 8px;
    padding: 8px 14px;
  }

  .hobby-title {
    font-size: 14px;
    font-weight: bold;
  }

  .hobby-desc {
    font-size: 12px;
    color: var(--color-text-muted);
  }

  /* ===== サブセクション見出し（推し） ===== */
  .subsection-title {
    font-size: 1.1em;
    font-weight: bold;
    letter-spacing: 0.08em;
    margin: 36px 0 16px;
    padding-left: 10px;
    border-left: 4px solid var(--color-accent);
    line-height: 1.3;
  }

  /* ===== 推し（小さめカードを横スクロール） ===== */
  .oshi-scroller {
    display: flex;
    gap: 14px;
    overflow-x: auto;
    padding-bottom: 10px;
    scroll-snap-type: x proximity;
    -webkit-overflow-scrolling: touch;
  }

  .oshi-card {
    flex: 0 0 auto;
    width: 140px;
    scroll-snap-align: start;
    border: 1px solid var(--color-border-light);
    border-radius: 10px;
    overflow: hidden;
    background: #fff;
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }

  .oshi-card:hover {
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.1);
    transform: translateY(-2px);
  }

  .oshi-img {
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
  }

  .oshi-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* 画像未設定時のプレースホルダー（ハート） */
  .oshi-img-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f5f5f5;
    color: var(--color-border-light);
    font-size: 36px;
  }

  .oshi-body {
    padding: 10px 12px 12px;
  }

  .oshi-category {
    display: inline-block;
    font-size: 9px;
    font-weight: 500;
    letter-spacing: 0.05em;
    padding: 2px 5px;
    margin-bottom: 6px;
    background: var(--color-accent);
    color: #fff;
  }

  .oshi-name {
    font-size: 13px;
    font-weight: bold;
    margin: 0 0 4px;
  }

  .oshi-desc {
    font-size: 11px;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin: 0;
  }
</style>
