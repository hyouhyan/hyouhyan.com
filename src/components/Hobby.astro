---
import { hobbies } from '../data/hobby';
import { oshi } from '../data/oshi';
---

<div class="hobby-box section" id="hobby">
  <div class="main-content">
    <h1 class="section-title"><span>HOBBY</span></h1>

    <div class="hobby-grid">
      {hobbies.map((h) => (
        <div class="hobby-card">
          <div class="hobby-icon">
            <i class={h.icon}></i>
          </div>
          <div class="hobby-body">
            <p class="hobby-title">{h.title}</p>
            <p class="hobby-desc">{h.description}</p>
          </div>
        </div>
      ))}
    </div>

    <h2 class="subsection-title">推し</h2>
    <div class="oshi-grid">
      {oshi.map((o) => {
        const Tag = o.url ? 'a' : 'div';
        const linkProps = o.url
          ? { href: o.url, target: '_blank', rel: 'noopener noreferrer' }
          : {};
        return (
          <Tag class="oshi-card" {...linkProps}>
            <div class="oshi-img">
              {o.img ? (
                <img src={o.img} alt={o.name} loading="lazy" />
              ) : (
                <span class="oshi-img-placeholder"><i class="fa-solid fa-heart"></i></span>
              )}
            </div>
            <div class="oshi-body">
              {o.category && <span class="oshi-category">{o.category}</span>}
              <p class="oshi-name">{o.name}</p>
              <p class="oshi-desc">{o.description}</p>
            </div>
          </Tag>
        );
      })}
    </div>
  </div>
</div>

<style>
  /* ===== 趣味カード ===== */
  .hobby-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .hobby-card {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    border: 1px solid var(--color-border-light);
    border-radius: 12px;
    padding: 20px;
    background: #fff;
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }

  .hobby-card:hover {
    box-shadow: 0 6px 24px rgba(0, 0, 0, 0.1);
    transform: translateY(-2px);
  }

  .hobby-icon {
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: var(--color-accent);
    color: #fff;
    font-size: 20px;
  }

  .hobby-body {
    min-width: 0;
  }

  .hobby-title {
    font-size: 15px;
    font-weight: bold;
    margin: 0 0 6px;
  }

  .hobby-desc {
    font-size: 13px;
    color: var(--color-text-muted);
    line-height: 1.65;
    margin: 0;
  }

  /* ===== サブセクション見出し（推し） ===== */
  .subsection-title {
    font-size: 1.2em;
    font-weight: bold;
    letter-spacing: 0.08em;
    margin: 48px 0 24px;
    padding-left: 12px;
    border-left: 4px solid var(--color-accent);
    line-height: 1.3;
  }

  /* ===== 推しカード ===== */
  .oshi-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .oshi-card {
    display: block;
    border: 1px solid var(--color-border-light);
    border-radius: 12px;
    overflow: hidden;
    background: #fff;
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }

  .oshi-card:hover {
    box-shadow: 0 6px 24px rgba(0, 0, 0, 0.1);
    transform: translateY(-2px);
  }

  .oshi-img {
    width: 100%;
    aspect-ratio: 3 / 4;
    overflow: hidden;
  }

  .oshi-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* 画像未設定時のプレースホルダー（ハート） */
  .oshi-img-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f5f5f5;
    color: var(--color-border-light);
    font-size: 48px;
  }

  .oshi-body {
    padding: 14px 16px 16px;
  }

  .oshi-category {
    display: inline-block;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.05em;
    padding: 2px 6px;
    margin-bottom: 8px;
    background: var(--color-accent);
    color: #fff;
  }

  .oshi-name {
    font-size: 15px;
    font-weight: bold;
    margin: 0 0 6px;
  }

  .oshi-desc {
    font-size: 13px;
    color: var(--color-text-muted);
    line-height: 1.65;
    margin: 0;
  }

  @media (max-width: 768px) {
    .hobby-grid,
    .oshi-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .hobby-grid,
    .oshi-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
