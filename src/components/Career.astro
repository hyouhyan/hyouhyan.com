---
import { career } from '../data/career';
import { publications } from '../data/publications';

// 著者リスト内で太字にする自分の表示名
const SELF_NAME = 'ひょうひゃん';
---

<div class="career-box section" id="career">
  <div class="main-content">
    <h1 class="section-title"><span>CAREER</span></h1>
    <div class="timeline">
      {career.map((item) => (
        <div class="timeline-item">
          <div class="timeline-year">
            <span class="timeline-year-num">{item.year}</span>
            <span class="timeline-month">{item.month ?? ''}</span>
          </div>
          <div class="timeline-content">
            <p class="timeline-title">
              {item.url ? (
                <a href={item.url} target="_blank" rel="noopener noreferrer">
                  {item.title}
                  <i class="fa-solid fa-arrow-up-right-from-square"></i>
                </a>
              ) : (
                item.title
              )}
            </p>
            {item.description && <p class="timeline-desc">{item.description}</p>}
          </div>
        </div>
      ))}
    </div>

    {publications.length > 0 && (
      <div class="publications" id="publications">
        <h2 class="subsection-title">Publications</h2>
        <ul class="pub-list">
          {publications.map((p) => (
            <li class="pub-item">
              {p.type && <span class="pub-type">{p.type}</span>}
              <p class="pub-title">
                {p.url ? (
                  <a href={p.url} target="_blank" rel="noopener noreferrer">
                    {p.title}
                    <i class="fa-solid fa-arrow-up-right-from-square"></i>
                  </a>
                ) : (
                  p.title
                )}
              </p>
              <p class="pub-authors">
                {p.authors.split(SELF_NAME).map((part, i, arr) => (
                  <>{part}{i < arr.length - 1 && <strong>{SELF_NAME}</strong>}</>
                ))}
              </p>
              <p class="pub-venue">{p.venue}, {p.year}</p>
              {p.award && <span class="pub-award">{p.award}</span>}
            </li>
          ))}
        </ul>
      </div>
    )}
  </div>
</div>

<style>
  .timeline {
    position: relative;
    padding-left: 32px;
  }

  /* 縦線 */
  .timeline::before {
    content: '';
    position: absolute;
    left: 0;
    top: 8px;
    bottom: 8px;
    width: 1px;
    background: var(--color-border);
  }

  .timeline-item {
    position: relative;
    display: flex;
    gap: 32px;
    padding-bottom: 48px;
  }

  .timeline-item:last-child {
    padding-bottom: 0;
  }

  /* ドット */
  .timeline-item::before {
    content: '';
    position: absolute;
    left: -36px;
    top: 10px;
    width: 9px;
    height: 9px;
    background: var(--color-accent);
    border-radius: 50%;
  }

  .timeline-year {
    display: flex;
    flex-direction: column;
    width: 56px;
    padding-top: 2px;
    flex-shrink: 0;
  }

  .timeline-year-num {
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
  }

  .timeline-month {
    font-size: 11px;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
    min-height: 1.4em;
  }

  .timeline-content {
    flex: 1;
    min-width: 0;
  }

  .timeline-title {
    font-size: 16px;
    font-weight: 700;
    margin: 0 0 6px;
    line-height: 1.4;
  }

  .timeline-title a {
    display: inline-flex;
    align-items: baseline;
    gap: 6px;
  }

  .timeline-title a:hover {
    text-decoration: underline;
  }

  .timeline-title a i {
    font-size: 0.7em;
    color: var(--color-text-muted);
  }

  .timeline-desc {
    font-size: 14px;
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.7;
  }


  .timeline a{
      color: #08c;
      cursor:pointer;
  }

  .timeline a:hover{
      color:#069;
  }

  @media (max-width: 767px) {
    .timeline {
      padding-left: 24px;
    }

    .timeline-item {
      gap: 20px;
      padding-bottom: 36px;
    }

    .timeline-item::before {
      left: -28px;
    }
  }

  /* ===== Publications（Career 内の h2 サブセクション） ===== */
  .publications {
    margin-top: 48px;
  }

  .subsection-title {
    font-size: 1.1em;
    font-weight: bold;
    letter-spacing: 0.08em;
    margin: 0 0 20px;
    padding-left: 10px;
    border-left: 4px solid var(--color-accent);
    line-height: 1.3;
  }

  .pub-list {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .pub-item {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .pub-type {
    align-self: flex-start;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.05em;
    padding: 2px 6px;
    margin-bottom: 2px;
    background: var(--color-accent);
    color: #fff;
  }

  .pub-title {
    font-size: 15px;
    font-weight: 700;
    margin: 0;
    line-height: 1.5;
  }

  .pub-title a {
    display: inline-flex;
    align-items: baseline;
    gap: 6px;
    color: #08c;
  }

  .pub-title a:hover {
    color: #069;
    text-decoration: underline;
  }

  .pub-title a i {
    font-size: 0.7em;
    color: var(--color-text-muted);
  }

  .pub-authors {
    font-size: 13px;
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.6;
  }

  .pub-authors strong {
    color: var(--color-text);
    font-weight: 700;
  }

  .pub-venue {
    font-size: 13px;
    color: var(--color-text-muted);
    font-style: italic;
    margin: 0;
    line-height: 1.6;
  }

  .pub-award {
    align-self: flex-start;
    font-size: 11px;
    font-weight: 600;
    margin-top: 4px;
    padding: 2px 8px;
    border: 1px solid var(--color-border);
    border-radius: 999px;
  }
</style>
