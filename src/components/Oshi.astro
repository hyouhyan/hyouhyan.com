---
import { oshi } from '../data/oshi';
---

<div class="oshi-box section" id="oshi">
  <div class="main-content">
    <h1 class="section-title"><span>OSHI</span></h1>
    <div class="oshi-grid">
      {oshi.map((o) => {
        const Tag = o.url ? 'a' : 'div';
        const linkProps = o.url
          ? { href: o.url, target: '_blank', rel: 'noopener noreferrer' }
          : {};
        return (
          <Tag class="oshi-card" {...linkProps}>
            <div class="oshi-img">
              {o.img ? (
                <img src={o.img} alt={o.name} loading="lazy" />
              ) : (
                <span class="oshi-img-placeholder"><i class="fa-solid fa-heart"></i></span>
              )}
            </div>
            <div class="oshi-body">
              {o.category && <span class="oshi-category">{o.category}</span>}
              <p class="oshi-name">{o.name}</p>
              <p class="oshi-desc">{o.description}</p>
            </div>
          </Tag>
        );
      })}
    </div>
  </div>
</div>

<style>
  .oshi-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .oshi-card {
    display: block;
    border: 1px solid var(--color-border-light);
    border-radius: 12px;
    overflow: hidden;
    background: #fff;
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }

  .oshi-card:hover {
    box-shadow: 0 6px 24px rgba(0, 0, 0, 0.1);
    transform: translateY(-2px);
  }

  .oshi-img {
    width: 100%;
    aspect-ratio: 3 / 4;
    overflow: hidden;
  }

  .oshi-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* 画像未設定時のプレースホルダー（ハート） */
  .oshi-img-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f5f5f5;
    color: var(--color-border-light);
    font-size: 48px;
  }

  .oshi-body {
    padding: 14px 16px 16px;
  }

  .oshi-category {
    display: inline-block;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.05em;
    padding: 2px 6px;
    margin-bottom: 8px;
    background: var(--color-accent);
    color: #fff;
  }

  .oshi-name {
    font-size: 15px;
    font-weight: bold;
    margin: 0 0 6px;
  }

  .oshi-desc {
    font-size: 13px;
    color: var(--color-text-muted);
    line-height: 1.65;
    margin: 0;
  }

  @media (max-width: 768px) {
    .oshi-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .oshi-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
